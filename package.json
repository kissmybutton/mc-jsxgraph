{
  "name": "mc-jsxgraph",
  "version": "0.0.1",
  "description": "MotorCortex plugin for geometric animations using JSXGraph",
  "main": "dist/bundle.cjs.js",
  "module": "dist/bundle.esm.js",
  "browser": "dist/bundle.umd.js",
