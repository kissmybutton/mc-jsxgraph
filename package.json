    "@rollup/plugin-node-resolve": "^16.0.1",
    "babel-loader": "^10.1.1",
    "canvas": "^3.2.2",
    "concurrently": "^9.1.2",
    "core-js": "^3.49.0",
    "css-loader": "7.1.4",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "9.1.2",
